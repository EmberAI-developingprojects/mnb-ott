### Сүүлийн 50 видео (VOD grid-д ашиглах)
GET {{baseUrl}}/playlistItems
  ?part=snippet,contentDetails
  &playlistId={{uploadsPlaylistId}}
  &maxResults=50
  &key={{apiKey}}

###

### Хуудас 2 — nextPageToken-г дээрх хариунаас хуулна
# @pageToken = EAAaHlBUOkNBb2lFREV5TVRFMU9EUkdSRFZDUlVORVJETQ
GET {{baseUrl}}/playlistItems
  ?part=snippet,contentDetails
  &playlistId={{uploadsPlaylistId}}
  &maxResults=10
  &pageToken=EAAaHlBUOkNBb2lFREV5TVRFMU9EUkdSRFZDUlVORVJETQ
  &key={{apiKey}}

###

# ─────────────────────────────────────────────
# 3. Видео дэлгэрэнгүй — DURATION энд байна
# ─────────────────────────────────────────────
### Олон видеоны duration + statistics нэгэн зэрэг (max 50 ID)
GET {{baseUrl}}/videos
  ?part=contentDetails,statistics,status,snippet
  &id=wTWtsHhKRGQ,EvnEgjMciQs,clgV4vhsKL4
  &key={{apiKey}}

