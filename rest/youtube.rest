### Quota зарцуулалт:
# search.list      = 100 unit / дуудалт  ← үнэтэй!
# playlistItems    =   1 unit / дуудалт  ← хямд
# videos.list      =   1 unit / дуудалт  ← хямд
# channels.list    =   1 unit / дуудалт  ← хямд
#
# СТРАТЕГИ: search ашиглахгүй, playlistItems + videos комбо ашиглана



GET https://www.googleapis.com/youtube/v3/search
  ?part=snippet
  &channelId=UCwtT_d7LZ8BJpiDXHV5RaAw
  &eventType=live
  &type=video
  &key={{apiKey}}

###
GET {{baseUrl}}/search
  ?part=snippet
  &channelId={{channelId}}
  &eventType=completed
  &type=video
  &maxResults=5
  &key={{apiKey}}

###

### upcoming broadcast байгаа эсэх
GET {{baseUrl}}/search
  ?part=snippet
  &channelId={{channelId}}
  &eventType=upcoming
  &type=video
  &maxResults=5
  &key={{apiKey}}