# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# МҮОНРТ OTT — BACKEND ENVIRONMENT VARIABLES
# Энэ файлыг .env болгон хуулаад утгуудыг бөглөнө
#   cp .env.example .env
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ── DATABASE (PostgreSQL) ─────────────────────────────
# Яаж авах:
#   Сонголт А — Docker (хамгийн хялбар):
#     docker run -d --name mnb-pg \
#       -e POSTGRES_USER=mnb \
#       -e POSTGRES_PASSWORD=mnb123 \
#       -e POSTGRES_DB=mnb \
#       -p 5432:5432 postgres:16
#   Сонголт Б — docker-compose-ийн postgres сервис (дараа тохируулна)
DATABASE_URL=postgresql://mnb:mnb123@localhost:5432/mnb

# ── REDIS (Cache) ─────────────────────────────────────
# Яаж авах:
#   Сонголт А — Docker:
#     docker run -d --name mnb-redis -p 6379:6379 redis:7
#   Сонголт Б — docker-compose-ийн redis сервис
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────
# Яаж авах:
#   Terminal дээр: openssl rand -base64 32
#   Гарсан утгыг JWT_SECRET-д оруул
#   АНХААР: NEXTAUTH_SECRET-тэй ижил байж болохгүй, тусдаа generate хий
JWT_SECRET=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# ── GOOGLE OAUTH (backend тал) ────────────────────────
# frontend/.env.local-ийн Google Console-оос авсан ижил утгуудыг оруул
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── SMS OTP ───────────────────────────────────────────
# Яаж авах (2 сонголт):
#
# Сонголт А — sms.mn (Монголын хамгийн түгээмэл):
#   1. https://sms.mn → Бүртгүүл
#   2. "API Keys" хэсгээс key авна
#   3. SMS_GATEWAY_URL=https://api.sms.mn/v1/send
#
# Сонголт Б — Mobicom MessagingAPI:
#   1. corporate.mobicom.mn → гэрээ байгуул
#
# ТУРШИЛТ ЗӨВЛӨМЖ:
#   SMS_MOCK=true болгоход SMS илгээхгүй, OTP-г console.log-оор харуулна
SMS_GATEWAY_URL=https://api.sms.mn/v1/send
SMS_API_KEY=
SMS_SENDER_ID=mnb
SMS_MOCK=true

# ── EMAIL (SMTP) ──────────────────────────────────────
# ТУРШИЛТ — өөрийн Gmail ашиглах:
#   1. Gmail → Settings → Security → 2-Step Verification идэвхжүүл
#   2. Security → "App passwords" → "Select app: Mail" → "Select device: Other"
#      → нэр өг (жишээ: mnb-dev) → "Generate"
#   3. Гарсан 16 тэмдэгтийг SMTP_PASS-д оруул (зай байхгүй)
#
# PRODUCTION руу шилжих үед:
#   SMTP_HOST=smtp.mnb.mn (МНБ-ийн mail server)
#   SMTP_USER=noreply@mnb.mn
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=uugnaauugaa56@gmail.com
SMTP_PASS=yyyfcksnlntjfrcu
SMTP_FROM="МҮОНРТ OTT <uugnaauugaa56@gmail.com>"

# ── AWS S3 (VOD storage) ──────────────────────────────
# Яаж авах:
#   1. https://console.aws.amazon.com
#   2. IAM → Users → Create user → "mnb-s3-user"
#   3. Permissions: "AmazonS3FullAccess" attach хий
#   4. Security credentials → Access keys → Create access key → хуул
#   5. S3 → Create bucket → нэр: "mnb-media" → Region: ap-northeast-1
#      "Block all public access" ИДЭВХТЭЙ байлга (CloudFront-оор харуулна)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-1
S3_BUCKET_NAME=mnb-media
CDN_BASE_URL=https://cdn.mnb.mn

# ── YOUTUBE API ───────────────────────────────────────
# Яаж авах:
#   1. Google Cloud Console (Google OAuth-д үүсгэсэн project-оо нэв)
#   2. "APIs & Services" → "Library" → "YouTube Data API v3" → Enable
#   3. "APIs & Services" → "Credentials" → "Create Credentials" → "API Key"
#   4. API key restrict: "API restrictions" → "YouTube Data API v3"
YOUTUBE_API_KEY=AIzaSy...
MNB_YOUTUBE_CHANNEL_ID=UCwtT_d7LZ8BJpiDXHV5RaAw


# ── QPAY (Төлбөр) ─────────────────────────────────────
# Яаж авах:
#   1. https://qpay.mn → "Бидэнтэй холбоо барих" → merchant account хүсэлт
#      Эсвэл: merchant@qpay.mn руу имэйл (Монголоор)
#      Агуулга: компанийн нэр, ТҮК, холбоо барих хүний нэр, утас
#   2. Тэд sandbox credential (username, password, invoice code) илгээнэ
#   3. Sandbox test дуусаад production credential тусдаа авна
# АНХААР: Sandbox болон production URL өөр байдаг

QPAY_BASE_URL=https://merchant-sandbox.qpay.mn/v2
QPAY_USERNAME=TEST_MERCHANT
QPAY_PASSWORD=123456
QPAY_INVOICE_CODE=TEST_INVOICE                                          
QPAY_CALLBACK_URL=https://example.com/qpay/callback

# ── SUBSCRIPTION PRICING ─────────────────────────────
PLAN_STANDARD_PRICE=9900
PLAN_PREMIUM_PRICE=19900
DEVICE_LIMIT_FREE=1
DEVICE_LIMIT_STANDARD=999
DEVICE_LIMIT_PREMIUM=999

# ── FIREBASE (FCM Push Notification) ─────────────────
# Яаж авах:
#   1. https://console.firebase.google.com → шинэ project ("mnb-ott")
#   2. Project Settings → Service accounts таб
#   3. "Generate new private key" → JSON файл татна
#   4. JSON файлаас: "project_id" → FCM_PROJECT_ID
#                    "private_key" → FCM_SERVER_KEY (бүтэн -----BEGIN...-г хамт)
FCM_PROJECT_ID=mnb-ott
FCM_SERVER_KEY=

# ── DVR / HLS (FFmpeg) ────────────────────────────────
# Яаж авах:
#   Mac: brew install ffmpeg
#   Ubuntu: sudo apt install ffmpeg
#   Зам шалгах: which ffmpeg  →  хариуг FFMPEG_PATH-д оруул
DVR_WINDOW_HOURS=2
HLS_SEGMENT_DURATION=6
FFMPEG_PATH=/opt/homebrew/bin/ffmpeg

# ── LIVE STREAM URLs ──────────────────────────────────
# .env-д байхгүй — Admin UI → Channels хэсгээс OPERATOR удирдана
# streamUrl нь Channel хүснэгтэд хадгалагдана (Prisma DB)

# ── DRM Widevine (Production-д л хэрэгтэй) ───────────
# Widevine license server — BuyDRM, Axinom, эсвэл Google Widevine-с авна
# Туршилтанд хэрэггүй, хоосон орхи
WIDEVINE_LICENSE_URL=
WIDEVINE_KEY_ID=
