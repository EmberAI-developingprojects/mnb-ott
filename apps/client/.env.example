# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# МҮОНРТ OTT — FRONTEND ENVIRONMENT VARIABLES
# Энэ файлыг .env.local болгон хуулаад утгуудыг бөглөнө
#   cp .env.example .env.local
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── APP ──────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="МҮОНРТ OTT"
NEXT_PUBLIC_API_URL=http://localhost:3001
# Туршилт: http://localhost:3000
# Production: https://ott.mnb.mn
NEXTAUTH_URL=http://localhost:3000

# ── NEXTAUTH SECRET ──────────────────────────────────
# Яаж авах: terminal дээр дараах командыг ажиллуул:
#   openssl rand -base64 32
# Гарсан утгыг доор оруул
NEXTAUTH_SECRET=

# ── GOOGLE OAUTH ─────────────────────────────────────
# Яаж авах:
#   1. https://console.cloud.google.com → шинэ project үүсгэ
#   2. "APIs & Services" → "Credentials" → "Create Credentials" → "OAuth 2.0 Client ID"
#   3. Application type: "Web application"
#   4. Authorized redirect URIs дотор нэм:
#      http://localhost:3000/api/auth/callback/google
#   5. Client ID болон Client Secret-ийг хуул
# ТУРШИЛТ: өөрийн gmail-тай холбосон Google Cloud project ашиглана
# PRODUCTION: МНБ-ийн Google Workspace account руу шилжүүлнэ
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── FIREBASE (Web Push Notification) ─────────────────
# Яаж авах:
#   1. https://console.firebase.google.com → project үүсгэ ("mnb-ott")
#   2. Project Settings → General → Your apps → Web app нэм
#   3. Project Settings → Cloud Messaging → Web Push certificates
#      → "Generate key pair" → VAPID key хуул
NEXT_PUBLIC_FCM_VAPID=

# ── PUBLIC CHANNEL IDs ────────────────────────────────
# МНБ-ийн YouTube channel-уудын ID (CLAUDE.md-д байгаа)
NEXT_PUBLIC_MNB_YOUTUBE_CHANNEL_ID=...

