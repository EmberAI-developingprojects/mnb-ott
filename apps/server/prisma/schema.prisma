generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // DATABASE_URL: transaction-mode pooler (port 6543) — runtime query-д
  // DIRECT_URL:   session-mode pooler (port 5432) — `prisma migrate`-д
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
  EDITOR
  OPERATOR
  SUPER_ADMIN
}

// 4 төрлийн plan:
//  BASIC : YouTube архив (үнэгүй) — анхдагч
//  TV    : Live TV + DVR + EPG
//  VOD   : Премиум видео сан
//  COMBO : TV + VOD аль аль
enum PlanType {
  BASIC
  TV
  VOD
  COMBO
}

enum SubStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum VodType {
  FREE
  PREMIUM
}

enum SourceType {
  YOUTUBE
  S3
}

enum PurchaseStatus {
  ACTIVE
  EXPIRED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum ContentType {
  LIVE
  VOD
}

model User {
  id          String    @id @default(cuid())
  phone       String?   @unique
  email       String?   @unique
  name        String?
  avatar      String?
  password    String?   // bcrypt hash, Google OAuth-д null
  role        Role      @default(USER)
  isVerified  Boolean   @default(false)
  isBlocked   Boolean   @default(false)  // Admin ban: true бол login хийж чадахгүй
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  accounts      Account[]
  sessions      UserSession[]
  subscription  Subscription?
  purchases     Purchase[]
  payments      Payment[]
  watchHistory  WatchHistory[]
  otpCodes      OtpCode[]
  notifications Notification[]
  auditLogs     AuditLog[]

  // Admin users page — role filter + createdAt desc sort
  @@index([role, createdAt])
  @@index([isBlocked])
}

// Admin-ийн үйлдлийн түүх — role change, refund, ban г.м.
model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String
  targetType   String   // "user" | "vod" | "channel" | "payment" | "config" | ...
  targetId     String?
  action       String   // "ROLE_CHANGE" | "BAN" | "REFUND" | "CREATE" | "UPDATE" | "DELETE"
  before       Json?
  after        Json?
  reason       String?
  ip           String?
  createdAt    DateTime @default(now())

  actor User @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId])
  @@index([targetType, targetId])
  @@index([createdAt])
  // Date-range filtering by target type (admin audit page)
  @@index([targetType, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model UserSession {
  id          String   @id @default(cuid())
  userId      String
  deviceId    String
  deviceName  String
  deviceType  String
  refreshToken String  @unique
  lastActive  DateTime @default(now())
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
}

model OtpCode {
  id        String   @id @default(cuid())
  userId    String
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Auth flow phone lookup + active OTP filter
  @@index([phone])
  @@index([userId, used])
}

model Subscription {
  id        String    @id @default(cuid())
  userId    String    @unique
  planType  PlanType  @default(BASIC)
  startedAt DateTime  @default(now())
  expiresAt DateTime?
  status    SubStatus @default(ACTIVE)
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Видео багц — энэ нь зүгээр л группчлэл (тематик цуглуулга).
// Дотор нь байгаа видео бүрийг ХЭРЭГЛЭГЧ НЭГ НЭГЭЭР НЬ түрээслэнэ (Purchase).
// Тогтсон үнэгүй "багц худалдаж авах" гэсэн ойлголт байхгүй.
model VodBundle {
  id           String   @id @default(cuid())
  title        String
  description  String?  @db.Text
  thumbnailUrl String?
  isActive     Boolean  @default(true)
  orderIndex   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items VodBundleItem[]
}

model VodBundleItem {
  id         String @id @default(cuid())
  bundleId   String
  vodId      String
  orderIndex Int    @default(0)

  bundle VodBundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  vod    VodContent @relation(fields: [vodId], references: [id], onDelete: Cascade)

  @@unique([bundleId, vodId])
}

// Хэрэглэгчид зориулсан мэдэгдэл (notifications)
enum NotificationType {
  SYSTEM
  SUBSCRIPTION
  PAYMENT
  CONTENT
  PROMO
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(SYSTEM)
  title     String
  body      String           @db.Text
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, isRead])
}

enum ChannelKind {
  LIVE   // МНБ-ийн үндсэн live broadcast (нэг бичлэг — тайлбар + URL)
  TV     // 5 TV суваг — thumbnail-тэй
  RADIO  // 2 радио суваг — thumbnail-тэй
}

model Channel {
  id           String      @id @default(cuid())
  name         String
  slug         String      @unique
  kind         ChannelKind @default(TV)
  streamUrl    String?
  epgUrl       String?
  thumbnailUrl String?
  isActive     Boolean     @default(true)
  orderIndex   Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model VodContent {
  id           String   @id @default(cuid())
  title        String
  description  String?  @db.Text
  thumbnailUrl String?
  genre        String?
  type         VodType  @default(FREE)
  price        Int?
  duration     Int?
  publishedAt  DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sources      VodSource[]
  purchases    Purchase[]
  bundleItems  VodBundleItem[]

  // Admin VOD list-д filter (type) + search (title) + sort (createdAt desc)
  @@index([type, createdAt])
  @@index([title])
  @@index([genre])
}

model VodSource {
  id         String     @id @default(cuid())
  vodId      String
  sourceType SourceType
  url        String
  youtubeId  String?
  drmKeyId   String?
  quality    String?
  createdAt  DateTime   @default(now())

  vod VodContent @relation(fields: [vodId], references: [id], onDelete: Cascade)
}

model Purchase {
  id        String         @id @default(cuid())
  userId    String
  vodId     String
  amount    Int
  expiresAt DateTime?
  status    PurchaseStatus @default(ACTIVE)
  createdAt DateTime       @default(now())

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  vod  VodContent @relation(fields: [vodId], references: [id], onDelete: Cascade)

  @@unique([userId, vodId])
}

model Payment {
  id             String        @id @default(cuid())
  userId         String
  invoiceId      String        @unique @default(cuid())
  qpayInvoiceId  String?
  amount         Int
  provider       String        @default("qpay")
  status         PaymentStatus @default(PENDING)
  metadata       Json?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Admin-аас удирддаг системийн тохиргоо (үнэ, хязгаар г.м.)
model SystemConfig {
  key       String   @id
  value     String
  label     String   // Admin UI-д харагдах нэр
  updatedAt DateTime @updatedAt
}

model WatchHistory {
  id          String      @id @default(cuid())
  userId      String
  contentId   String
  contentType ContentType
  positionSec Int         @default(0)
  updatedAt   DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId, contentType])
}
